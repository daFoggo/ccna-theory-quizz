# Client (Prefix with VITE_)
VITE_API_CORE_URL=
VITE_API_AI_URL=
VITE_APP_NAME="ccna_theory"
VITE_TELEGRAM_LOGIN_CLIENT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_KEY=

# For Telegram local testing, `pnpm dev:tunnel` rewrites VITE_API_CORE_URL
# to the backend ngrok tunnel before starting Vite.

# Server (Secure) — Optional for frontend development; required for backend-dependent features
DATABASE_URL=
OPEN_AI_API_KEY=
SELINE_TOKEN=
# REQUIRED (production). Generate with: openssl rand -hex 32
SESSION_SECRET=
